{
  "name": "@proxysoul/soulforge",
  "version": "1.0.0",
  "description": "AI-Powered Terminal IDE by proxySoul",
  "repository": {
    "type": "git",
    "url": "https://github.com/proxysoul/soulforge.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "module": "src/boot.tsx",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "proxySoul",
  "bin": {
    "soulforge": "./dist/index.js",
    "sf": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/boot.tsx",
    "build": "bun build src/boot.tsx --outdir dist --target bun --external react-devtools-core --entry-naming \"[dir]/index.[ext]\"",
    "build:binary": "bun build src/index.tsx --compile --external react-devtools-core --outfile bin/soulforge",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run build",
    "release": "bun run build && npm publish"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "^2.4.5",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.10",
    "@types/linkify-it": "^5.0.0",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.55",
    "@ai-sdk/google": "^3.0.37",
    "@ai-sdk/openai": "^3.0.39",
    "@ai-sdk/xai": "^3.0.64",
    "@mozilla/readability": "^0.6.0",
    "@opentui/react": "^0.1.86",
    "ai": "^6.0.112",
    "chalk": "^5.6.2",
    "linkedom": "^0.18.12",
    "linkify-it": "^5.0.0",
    "marked": "^17.0.4",
    "neovim": "^5.4.0",
    "react": "^19.2.4",
    "shiki": "^4.0.1",
    "tree-sitter-wasms": "^0.1.13",
    "ts-morph": "^27.0.2",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  }
}
